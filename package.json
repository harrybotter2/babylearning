{
  "name": "babylearning",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "node",
        "testMatch": ["**/__tests__/utils/**/*.test.ts", "**/__tests__/db/**/*.test.ts"],
        "transform": {
          "^.+\\.(ts|tsx)$": ["babel-jest", {"presets": ["babel-preset-expo"]}]
        },
        "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"]
      }
    ]
  },
  "dependencies": {
    "expo": "~55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-speech": "~55.0.9",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-worklets": "^0.8.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "typescript": "~5.9.2"
  },
  "private": true
}
